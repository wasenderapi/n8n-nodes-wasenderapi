{
	"name": "n8n-nodes-wasenderapi",
	"version": "0.1.0",
	"description": "n8n community node for WasenderAPI",
	"license": "MIT",
	"homepage": "https://github.com/wasenderapi/n8n-nodes-wasenderapi",
	"author": {
		"name": "Yonko"
	},
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/wasenderapi/n8n-nodes-wasenderapi.git"
	},
	"bugs": {
		"url": "https://github.com/wasenderapi/n8n-nodes-wasenderapi/issues"
	},
	"engines": {
		"node": ">=20.15"
	},
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"workflow",
		"automation",
		"wasenderapi",
		"whatsapp"
	],
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/WasenderAccountApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/WasenderApi/WasenderApi.node.js",
			"dist/nodes/WasenderApiTrigger/WasenderApiTrigger.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.32.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
